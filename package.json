{
  "name": "article-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_ALGOLIA_INDICES=hatenablog,til NEXT_PUBLIC_API_MOCKING=enabled next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "lint:format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "NEXT_PUBLIC_ALGOLIA_INDICES=hatenablog,til NEXT_PUBLIC_API_MOCKING=enabled vitest run"
  },
  "dependencies": {
    "@algolia/client-search": "5.52.0",
    "algoliasearch": "5.52.0",
    "instantsearch.js": "4.95.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-instantsearch": "^7.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "jsdom": "29.1.0",
    "msw": "2.14.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@11.0.3",
  "pnpm": {
    "onlyBuiltDependencies": ["msw", "sharp", "unrs-resolver"]
  },
  "resolutions": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
