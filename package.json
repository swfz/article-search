{
  "name": "article-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_ALGOLIA_INDICES=hatenablog,til NEXT_PUBLIC_API_MOCKING=enabled next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "lint:format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
